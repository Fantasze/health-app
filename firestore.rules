rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Helper function to check if user is coach
    function isCoach() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    
    // Users collection - 用户只能读写自己的数据
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Coaches collection - 教练信息可公开读，只有管理员可写
    match /coaches/{coachId} {
      allow read: if true; // 教练信息可以公开读
      allow create: if isAdmin();
      allow update: if isAdmin() || (isCoach() && request.auth.uid == coachId);
      allow delete: if isAdmin();
    }
    
    // Coach Registrations - 只有管理员可以审核
    match /coachRegistrations/{regId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAuthenticated(); // 用户可以提交申请
    }
    
    // Students collection - 学生和教练可以读，学生可以写自己的数据
    match /students/{studentId} {
      allow read: if isAuthenticated(); // 认证用户可以读
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Sessions collection - 课程数据
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isCoach();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Weights collection - 体重记录
    match /weights/{weightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Meals collection - 饮食记录
    match /meals/{mealId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Sales Codes - 销售码管理
    match /salesCodes/{codeId} {
      allow read: if isAuthenticated(); // 认证用户可以读
      allow create: if isAdmin(); // 只有管理员可以创建
      allow update: if isAdmin(); // 只有管理员可以更新
      allow delete: if isAdmin();
    }
    
    // Admins collection - 管理员信息
    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if isOwner(adminId);
    }
  }
}
